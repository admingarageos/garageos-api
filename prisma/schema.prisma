enum RolTaller {
  admin
  mecanico
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoOrden {
  pendiente
  en_proceso
  terminada
  entregada
  cancelada
}

enum MetodoPago {
  efectivo
  tarjeta
  transferencia
}

model Taller {
  id         Int      @id @default(autoincrement())
  nombre     String
  telefono   String?
  direccion  String?
  logo       String?
  suspendido Boolean  @default(false)

  // Licenciamiento
  licenciaVence        DateTime?
  planTipo             String?   @default("trial")  // "trial" | "basico" | "estandar" | "pro" | "manual"

  // Stripe
  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())

  clientes          Cliente[]
  vehiculos         Vehiculo[]
  ordenes           OrdenServicio[]
  usuarios          UserTaller[]
  citas             Cita[]
  pushSubscriptions PushSubscription[]
  invitaciones      Invitacion[]
  refacciones       Refaccion[]
}

model PlatformConfig {
  key   String @id
  value String
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String
  email     String?

  tallerId  Int
  taller    Taller   @relation(fields: [tallerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehiculos Vehiculo[]
  citas     Cita[]

  @@index([tallerId])
}

model Vehiculo {
  id       Int    @id @default(autoincrement())
  marca    String
  modelo   String
  anio     Int
  placas   String

  clienteId Int
  cliente   Cliente @relation(fields: [clienteId], references: [id])

  tallerId Int
  taller   Taller @relation(fields: [tallerId], references: [id])

  ordenes         OrdenServicio[]
  citas           Cita[]
  placaHistorial  PlacaHistorial[]

  @@unique([placas, tallerId])
  @@index([clienteId])
}

model PlacaHistorial {
  id          Int      @id @default(autoincrement())
  placa       String
  fechaCambio DateTime @default(now())

  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([vehiculoId])
}

model OrdenServicio {
  id            Int         @id @default(autoincrement())
  descripcion   String?
  notasInternas String?

  fecha         DateTime    @default(now())
  fechaEntrega  DateTime?                    // ✅ Se llena al pasar a "entregada"
  estado        EstadoOrden @default(pendiente)
  total         Float       @default(0)

  kilometraje   Int?

  // Método de pago — se registra al cobrar (terminada/entregada)
  metodoPago    MetodoPago?

  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id])

  tallerId Int
  taller   Taller @relation(fields: [tallerId], references: [id])

  detalles     OrdenServicioDetalle[]
  cita         Cita?
  comentarios  OrdenComentario[]

  @@index([vehiculoId])
  @@index([tallerId])
  @@index([estado])
  @@index([metodoPago])
}

model Servicio {
  id     Int    @id @default(autoincrement())
  nombre String
  precio Float

  detalles OrdenServicioDetalle[]
}

model OrdenServicioDetalle {
  id Int @id @default(autoincrement())

  ordenId    Int
  servicioId Int
  cantidad   Int   @default(1)
  precio     Float

  orden    OrdenServicio @relation(fields: [ordenId], references: [id])
  servicio Servicio      @relation(fields: [servicioId], references: [id])

  @@index([ordenId])
  @@index([servicioId])
}

model User {
  id           Int     @id @default(autoincrement())
  nombre       String
  email        String  @unique
  passwordHash String
  superAdmin   Boolean @default(false)

  resetToken        String?   @unique
  resetTokenExpires DateTime?

  createdAt DateTime @default(now())

  talleres          UserTaller[]
  comentarios       OrdenComentario[]
  pushSubscriptions PushSubscription[]
  invitaciones      Invitacion[]
}

model OrdenComentario {
  id        Int      @id @default(autoincrement())
  texto     String
  createdAt DateTime @default(now())

  ordenId Int
  orden   OrdenServicio @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ordenId])
}

model UserTaller {
  id Int @id @default(autoincrement())

  userId   Int
  tallerId Int

  rol RolTaller @default(mecanico)

  user   User   @relation(fields: [userId], references: [id])
  taller Taller @relation(fields: [tallerId], references: [id])

  @@unique([userId, tallerId])
  @@index([tallerId])
}

enum EstadoCita {
  pendiente
  confirmada
  cancelada
  completada
}

model Cita {
  id          Int        @id @default(autoincrement())
  fecha       DateTime
  descripcion String?
  estado      EstadoCita @default(pendiente)

  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id])

  tallerId Int
  taller   Taller @relation(fields: [tallerId], references: [id])

  ordenId Int?           @unique
  orden   OrdenServicio? @relation(fields: [ordenId], references: [id])

  createdAt DateTime @default(now())

  @@index([tallerId])
  @@index([clienteId])
  @@index([fecha])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String
  p256dh    String
  auth      String
  userId    Int
  tallerId  Int
  user      User     @relation(fields: [userId],   references: [id], onDelete: Cascade)
  taller    Taller   @relation(fields: [tallerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([endpoint, tallerId])
  @@index([tallerId])
  @@index([userId])
}

model Refaccion {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  sku         String?
  precioCosto Float    @default(0)
  precioVenta Float    @default(0)
  stock       Int      @default(0)
  stockMinimo Int      @default(5)

  tallerId Int
  taller   Taller @relation(fields: [tallerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tallerId])
}

model Invitacion {
  id        Int        @id @default(autoincrement())
  token     String     @unique
  rol       RolTaller  @default(mecanico)
  expiresAt DateTime
  usadaAt   DateTime?
  createdAt DateTime   @default(now())

  tallerId  Int
  taller    Taller @relation(fields: [tallerId], references: [id])

  creadoPor Int
  creador   User   @relation(fields: [creadoPor], references: [id])

  @@index([tallerId])
  @@index([token])
}
